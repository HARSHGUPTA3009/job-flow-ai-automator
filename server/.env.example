# =========================
# SERVER CONFIG
# =========================
PORT=3001
NODE_ENV=development

CLIENT_URL=https://autojobflow.vercel.app
VITE_API_URL=https://jobflow-backend-ai.onrender.com

# =========================
# AUTH / SESSION
# =========================
SESSION_SECRET=your-super-secret-session-key

# =========================
# GROQ API KEYS (LOAD BALANCING)
# =========================
GROQ_KEY_1=your_groq_key_1
GROQ_KEY_2=your_groq_key_2
GROQ_KEY_3=your_groq_key_3

# =========================
# GOOGLE OAUTH
# =========================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://jobflow-backend-ai.onrender.com/auth/google/callback

# =========================
# DATABASE
# =========================
MONGODB_URI=your_mongodb_connection_string

# =========================
# EMAIL (SMTP / GMAIL)
# =========================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# =========================
# ADMIN
# =========================
ADMIN_SECRET=your_admin_secret

# =========================
# REDIS
# =========================
REDIS_URL=redis://127.0.0.1:6379