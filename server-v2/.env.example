# ─────────────────────────────────────────────────────────────────────────────
# AutoJobFlow — server-v2 Environment Variables
# The v2 gateway shares the same .env values as the original server.
# Copy this file to .env (or reuse the same .env from server/)
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# v2 gateway runs on a DIFFERENT port from the old server (which uses 3001)
PORT=3002
WORKER_PORT=3003

# ── Database (same as original server)
MONGODB_URI=your_mongodb_connection_string

# ── Redis (same as original server)
# Local:   redis://localhost:6379
# Upstash: rediss://:password@host:6379
REDIS_URL=redis://localhost:6379

# ── Auth
# SESSION_SECRET is used by the original server (passport sessions)
SESSION_SECRET=your-super-secret-session-key

# JWT_SECRET is used by v2 gateway for Bearer token auth
# Can be any long random string — different from SESSION_SECRET is fine
JWT_SECRET=autojobflow-v2-jwt-secret-change-this-in-production

# ── Google OAuth (same values as original server)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://jobflow-backend-ai.onrender.com/auth/google/callback
# GOOGLE_CALLBACK_URL is an alias — v2 will read either name
GOOGLE_CALLBACK_URL=https://jobflow-backend-ai.onrender.com/auth/google/callback

# ── Groq API Keys
# Supports BOTH formats — use whichever you already have:
# Old format (individual keys):
GROQ_KEY_1=gsk_your_key_1
GROQ_KEY_2=gsk_your_key_2
GROQ_KEY_3=gsk_your_key_3
# New format (comma-separated, takes precedence if set):
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# ── App URLs (same as original server)
CLIENT_URL=https://autojobflow.vercel.app
VITE_API_URL=https://jobflow-backend-ai.onrender.com

# ── Rate Limiting (v2 defaults — override if needed)
GLOBAL_RATE_LIMIT=500
USER_RATE_LIMIT=100
ATS_HOURLY_LIMIT=10

# ── Queue settings
MAX_JOB_ATTEMPTS=5
JOB_BACKOFF_BASE_MS=1000
